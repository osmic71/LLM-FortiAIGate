ion_detail.match(\"'type':[[:space:]]*'([^']+)'\")", "threat_direction = v_violation_detail.match(\"'direction':[[:space:]]*'([^']+)'\")", "threat_message   = v_violation_detail.match(\"'details':[[:space:]]*'([^']+)'\")"]}}, "field_map": {"data_sourcetype": ["data_sourcetype"], "data_sourceid": ["data_sourceid"], "data_sourcename": ["data_sourcename"], "data_timestamp": ["data_timestamp"], "event_id": ["v_log_id", "v_id"], "event_uuid": ["v_request_id"], "event_type": ["v_type"], "event_subtype": ["v_subtype"], "event_severity": ["v_level", "v_pri"], "event_action": ["v_action"], "event_status": ["v_status"], "event_outcome": ["v_verdict"], "event_profile": ["v_ai_flow_name"], "event_ref": ["v_ai_flow_uuid"], "event_resource_id": ["v_ai_guard_uuid"], "event_policy": ["v_ai_guard_name"], "event_source": ["v_ai_guard_type"], "event_tags": ["v_call_type"], "event_message": ["v_prompt_original"], "event_rawmsg": ["msg_body"], "event_start_time": ["v_start_time"], "event_end_time": ["v_end_time"], "event_duration": ["v_total_duration_ms"], "event_cat": ["v_subtype"], "event_count": ["v_total_tokens"], "src_ip": ["v_requester_ip"], "src_geo": ["v_srcgeoid"], "dst_geo": ["v_dstgeoid"], "user_name": ["v_user"], "user_email": ["v_user"], "user_id": ["v_euid"], "app_name": ["v_model"], "app_ver": ["v_model_id"], "app_cat": ["v_model_group"], "app_service": ["v_llm_endpoint"], "app_ref": ["v_llm_provider"], "app_proc": ["v_mcp_tool"], "app_state": ["v_status"], "http_url": ["v_llm_endpoint"], "http_response_body": ["v_response_original"], "http_response_time": ["v_llm_duration_ms"], "net_sentbytes": ["v_prompt_tokens"], "net_recvbytes": ["v_completion_tokens"], "net_sessionduration": ["v_total_duration_ms"], "net_sessionid": ["v_session_id"], "threat_message": ["threat_message"], "threat_score": ["v_spend"], "threat_name": ["threat_type"], "threat_ref": ["v_ai_guard_uuid"], "process_id": ["v_epid"], "host_name": ["data_sourcename"], "host_ip": ["v_requester_ip"], "dns_query":