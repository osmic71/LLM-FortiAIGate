{"header": {"name": "FortiAIGate Log Parser", "category": "Fortinet Device", "application": "Syslog", "author": "Fortinet", "change_time": "2026-04-13 11:27:33", "version": "7.6.5"}, "data_source": {"matchers": [{"description": "FortiAIGate AI proxy logs - matched by log_id=20100001 and ai_guard_uuid unique to FortiAIGate", "type": "syslog", "patterns": ["^(?<msg_body>.*log_id=20100001.*ai_guard_uuid=[[:graph:]]+.*)$"]}]}, "parser": {"rules": {"rule_parse": {"description": "Parse todos los campos del glog de FortiAIGate (outer envelope + inner msg) via match_logfmt", "trigger": {"expression": "${condition_1}", "condition_1": "${msg_body}.is_not_empty()"}, "actions": ["match_logfmt(msg_body)", "data_sourcetype     = \"FortiAIGate\"", "data_sourceid       = coalesce(${_device_id}, ${device_id})", "data_sourcename     = coalesce(${_devname}, ${devname})", "data_timestamp      = epoch_timestamp(coalesce(${_itime_t}, ${itime_t}))", "v_date              = coalesce(${_date}, ${date})", "v_time              = coalesce(${_time}, ${time})", "v_id                = coalesce(${_id}, ${id})", "v_euid              = coalesce(${_euid}, ${euid})", "v_epid              = coalesce(${_epid}, ${epid})", "v_logflag           = coalesce(${_logflag}, ${logflag})", "v_level             = coalesce(${_level}, ${level})", "v_srcgeoid          = coalesce(${_srcgeoid}, ${srcgeoid})", "v_dstgeoid          = coalesce(${_dstgeoid}, ${dstgeoid})", "v_log_id            = ${_log_id}", "v_msg_id            = ${_msg_id}", "v_timezone          = ${_timezone}", "v_type              = ${_type}", "v_subtype           = ${_subtype}", "v_pri               = ${_pri}", "v_request_id        = ${_request_id}", "v_call_type         = ${_call_type}", "v_ai_flow_name      = ${_ai_flow_name}", "v_ai_flow_uuid      = ${_ai_flow_uuid}", "v_ai_guard_uuid     = ${_ai_guard_uuid}", "v_ai_guard_name     = ${_ai_guard_name}", "v_ai_guard_type     = ${_ai_guard_type}", "v_user              = ${_user}", "v_requester_ip      =